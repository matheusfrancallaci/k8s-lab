# Copie para terraform.tfvars e preencha.

# Conteúdo da sua chave SSH pública (cat ~/.ssh/id_ed25519.pub)
ssh_public_key = "ssh-ed25519 AAAA... você@maquina"

# Senha compartilhada de acesso — o gate para os amigos
app_password = "troque-esta-senha"

# Recomendado: restrinja o SSH ao seu IP (veja o seu em https://ifconfig.me)
# allowed_ssh_cidr = "200.1.2.3/32"

# Opcional: rótulo DNS -> http://<label>.brazilsouth.cloudapp.azure.com
# dns_label = "meu-k8s-lab"

# Opcional: região e tamanho
# location = "brazilsouth"
# vm_size  = "Standard_B2s"
